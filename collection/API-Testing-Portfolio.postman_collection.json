									"pm.test('Response has token or id', function() {",
									"    const json = pm.response.json();",
									"    pm.expect(json.hasOwnProperty('token') || json.hasOwnProperty('id')).to.be.true;",
									"    if (json.token) pm.collectionVariables.set('authToken', json.token);",
									"});"
								]
							}
						}
