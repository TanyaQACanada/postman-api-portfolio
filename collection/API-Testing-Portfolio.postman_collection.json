					"name": "Check rate limit headers (contract)",
					"event": [
						{
							"listen": "test",
							"script": {
								"type": "text/javascript",
								"exec": [
									"pm.test('Status code is 200 or 429', function() {",
									"    pm.expect([200, 429]).to.include(pm.response.code);",
									"});",
									"// If 429, expect Retry-After or X-RateLimit-* headers (contract check)",
									"if (pm.response.code === 429) {",
									"    pm.test('429 response has Retry-After or rate limit header', function() {",
									"        const hasRetry = pm.response.headers.has('Retry-After');",
									"        const hasLimit = pm.response.headers.has('X-RateLimit-Limit') || pm.response.headers.has('X-RateLimit-Remaining');",
									"        pm.expect(hasRetry || hasLimit).to.be.true;",
									"    });",
									"}"
								]
							}
						}
					],
