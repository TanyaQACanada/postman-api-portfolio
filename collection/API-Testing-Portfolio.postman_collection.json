{
	"info": {
		"_postman_id": "api-testing-portfolio-001",
		"name": "API Testing Portfolio - ReqRes",
		"description": "Senior-level Postman collection: Auth, CRUD, Negative, Pagination, Idempotency, Concurrency, Security, Contract, Smoke, Regression, E2E.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "authToken", "value": "" },
		{ "key": "createdUserId", "value": "" },
		{ "key": "createdUserJob", "value": "" },
		{ "key": "idempotencyKey", "value": "" },
		{ "key": "e2eUserId", "value": "" },
		{ "key": "e2eUpdateId", "value": "" }
	],
	"auth": { "type": "noauth" },
	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Reusable: set Bearer token if present",
					"if (pm.collectionVariables.get('authToken')) {",
					"    pm.request.headers.upsert({ key: 'Authorization', value: 'Bearer ' + pm.collectionVariables.get('authToken') });",
					"}",
					"// Reusable: ensure JSON accept",
					"pm.request.headers.upsert({ key: 'Accept', value: 'application/json' });",
					"// ReqRes: User-Agent reduces 403 in CI (reqres.in/blog/qa-automation-with-reqres)",
					"pm.request.headers.upsert({ key: 'User-Agent', value: 'reqres-qa-tests/1.0' });",
					"var apiKey = pm.environment.get('apiKey') || pm.collectionVariables.get('apiKey');",
					"if (apiKey) { pm.request.headers.upsert({ key: 'x-api-key', value: apiKey }); }"
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"// Reusable: assert status code",
					"function assertStatus(code) {",
					"    pm.test('Status code is ' + code, function() { pm.response.to.have.status(code); });",
					"}",
					"// Reusable: assert response time under threshold (ms)",
					"function assertResponseTime(threshold) {",
					"    pm.test('Response time is below ' + threshold + ' ms', function() {",
					"        pm.expect(pm.response.responseTime).to.be.below(threshold);",
					"    });",
					"}",
					"// Reusable: assert JSON schema has required top-level keys",
					"function assertHasKeys(obj, keys) {",
					"    keys.forEach(function(k) { pm.expect(obj).to.have.property(k); });",
					"}"
				]
			}
		}
	],
	"item": [
